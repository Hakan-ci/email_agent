# ========================================
# AI-Powered Gmail Intelligence System
# Environment Variables Template
# ========================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value below.
#   3. NEVER commit the .env file to version control.
# ========================================

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ---------- Gmail API (OAuth 2.0) ----------
# Path to the OAuth 2.0 client credentials JSON downloaded from Google Cloud Console.
GMAIL_CREDENTIALS_PATH=credentials.json
# Path where the authenticated token will be cached after first login.
GMAIL_TOKEN_PATH=token.json
# Maximum number of emails to fetch per polling cycle.
GMAIL_MAX_RESULTS=5

# ---------- PostgreSQL Database ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=email_agent
DB_USER=postgres
DB_PASSWORD=your-database-password-here

# ---------- Telegram Bot ----------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ---------- Application Settings ----------
# Polling interval in seconds between each email check cycle.
POLLING_INTERVAL=60
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
